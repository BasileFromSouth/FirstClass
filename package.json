  },
  "files": [
    "storybook-static"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build-storybook",
    "chromatic": "chromatic --exit-zero-on-changes --force-rebuild",
    "storybook:publish": "node scripts/chromatic-with-env.cjs",
    "figma:connect:parse": "node scripts/figma-with-env.cjs connect parse",
    "figma:connect:publish": "node scripts/figma-with-env.cjs connect publish",
    "figma:connect:publish:dry-run": "node scripts/figma-with-env.cjs connect publish --dry-run",
    "publish:figma": "node scripts/publish-figma-npm.cjs"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@figma/code-connect": "^1.4.2",
