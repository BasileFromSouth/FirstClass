{
  "name": "@stoodio-design-system/stoodio-design-system",
  "version": "0.1.0",
  "description": "Stoodio design system — React components and static Storybook documentation.",
  "keywords": [
    "design-system",
    "storybook",
    "react",
    "stoodio",
    "components"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BasileFromSouth/FirstClass.git"
  },
  "bugs": {
    "url": "https://github.com/BasileFromSouth/FirstClass/issues"
  },
  "homepage": "https://github.com/BasileFromSouth/FirstClass#readme",
